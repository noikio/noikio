# Backend
PORT=3000
NODE_ENV=development

# CORS — comma-separated list of allowed origins in production
ALLOWED_ORIGINS=http://localhost:4200

# Session token header trust (set true when behind a reverse proxy like Railway/Nginx)
TRUST_PROXY=false

# Email (OTP delivery) — leave blank for dev-mode console fallback
RESEND_API_KEY=
FROM_EMAIL=otp@yourdomain.com

# Admin dashboard access — set to the email address of the admin account
ADMIN_EMAIL=admin@yourdomain.com

# AI execution (v1 stubs — not yet implemented)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
